@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider

<div class="d-flex vh-100">
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column text-white" style="width: 260px; background: #1a237e;">
        <div class="p-3 border-bottom border-light border-opacity-25">
            <h5 class="mb-0">
                <i class="bi bi-mailbox2-flag me-2" style="color: #f5c518;"></i>
                <span style="color: #f5c518;">Swiss</span> Postal
            </h5>
        </div>
        <ul class="nav flex-column p-2 flex-grow-1">
            <li class="nav-item">
                <a class="nav-link text-white" href="/app">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>

            @* OPERATIONS: visible to all authenticated users *@
            <li class="nav-item mt-2">
                <small class="text-white-50 px-3">OPERATIONS</small>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/app/parcels">
                    <i class="bi bi-box-seam me-2"></i> Parcels
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/app/tracking">
                    <i class="bi bi-geo-alt me-2"></i> Tracking
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/app/delivery">
                    <i class="bi bi-truck me-2"></i> Deliveries
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/app/pickups">
                    <i class="bi bi-bag-check me-2"></i> Pickups
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white" href="/app/inbox">
                    <i class="bi bi-inbox me-2"></i> Inbox
                </a>
            </li>

            @* MANAGEMENT: ADMIN and BRANCH_MANAGER only *@
            <AuthorizeView Roles="ADMIN,BRANCH_MANAGER">
                <li class="nav-item mt-2">
                    <small class="text-white-50 px-3">MANAGEMENT</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/branches">
                        <i class="bi bi-building me-2"></i> Branches
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/employees">
                        <i class="bi bi-people me-2"></i> Employees
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/customers">
                        <i class="bi bi-person-badge me-2"></i> Customers
                    </a>
                </li>
            </AuthorizeView>

            @* SYSTEM: ADMIN only *@
            <AuthorizeView Roles="ADMIN">
                <li class="nav-item mt-2">
                    <small class="text-white-50 px-3">SYSTEM</small>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/addresses">
                        <i class="bi bi-signpost-2 me-2"></i> Addresses
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/notifications">
                        <i class="bi bi-bell me-2"></i> Notification Log
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/notifications/templates">
                        <i class="bi bi-file-earmark-code me-2"></i> Templates
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" href="/app/notifications/send-inapp">
                        <i class="bi bi-megaphone me-2"></i> Send Notification
                    </a>
                </li>
            </AuthorizeView>
        </ul>
    </nav>

    <!-- Main content -->
    <div class="flex-grow-1 d-flex flex-column">
        <!-- Topbar -->
        <header class="topbar d-flex align-items-center justify-content-between px-4 py-2 bg-white border-bottom shadow-sm">
            <h6 class="mb-0 text-muted">Swiss Postal Platform</h6>
            <div class="d-flex align-items-center gap-3">
                <NotificationBell />
                <span class="text-muted small">@_displayName</span>
                <a href="/logout" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </a>
            </div>
        </header>

        <!-- Page body -->
        <main class="flex-grow-1 overflow-auto p-4 bg-light">
            @Body
        </main>
    </div>
</div>

@code {
    private string _displayName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _displayName = user.FindFirst("name")?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? user.Identity?.Name
            ?? "User";
    }
}
