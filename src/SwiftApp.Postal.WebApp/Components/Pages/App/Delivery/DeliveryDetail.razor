@page "/app/delivery/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject SwiftApp.Postal.Modules.Delivery.Application.Services.DeliveryRouteService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Delivery.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Route Detail — Swiss Postal</PageTitle>

@if (_route is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="bi bi-truck me-2" style="color:#1a237e"></i><code>@_route.RouteCode</code></h2>
        <a href="/app/delivery" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-semibold">Route Information</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-sm-5">Route Code</dt>
                        <dd class="col-sm-7"><code>@_route.RouteCode</code></dd>
                        <dt class="col-sm-5">Date</dt>
                        <dd class="col-sm-7">@_route.Date.ToString("dddd, dd MMMM yyyy")</dd>
                        <dt class="col-sm-5">Status</dt>
                        <dd class="col-sm-7"><StatusBadge Status="@_route.Status" /></dd>
                        <dt class="col-sm-5">Total Slots</dt>
                        <dd class="col-sm-7">@_route.TotalSlots</dd>
                        <dt class="col-sm-5">Created</dt>
                        <dd class="col-sm-7 text-muted">@_route.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private DeliveryRouteResponse? _route;

    protected override async Task OnInitializedAsync()
    {
        try { _route = await Service.GetByIdAsync(Id); }
        catch { Nav.NavigateTo("/app/delivery"); }
    }
}
