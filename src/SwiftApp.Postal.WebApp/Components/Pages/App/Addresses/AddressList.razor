@page "/app/addresses"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "ADMIN")]
@inject SwiftApp.Postal.Modules.Address.Application.Services.SwissAddressService Service
@using SwiftApp.Postal.Modules.Address.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Swiss Address Lookup — Swiss Postal</PageTitle>

<div class="mb-3">
    <h2 class="mb-0"><i class="bi bi-pin-map me-2" style="color:#1a237e"></i>Swiss Address Lookup</h2>
    <p class="text-muted small mt-1">Search the Swiss postal address database (PTT)</p>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label fw-semibold small">ZIP Code</label>
                <input class="form-control" @bind="_filterZip" placeholder="8001" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold small">City</label>
                <input class="form-control" @bind="_filterCity" placeholder="Zürich" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold small">Canton</label>
                <input class="form-control" @bind="_filterCanton" placeholder="ZH" maxlength="2" />
            </div>
            <div class="col-md-auto">
                <button class="btn btn-primary" @onclick="SearchAsync" disabled="@_searching">
                    @if (_searching) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <i class="bi bi-search me-1"></i> Search
                </button>
                <button class="btn btn-outline-secondary ms-2" @onclick="Reset">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (_items is not null)
{
    <div class="card shadow-sm border-0">
        <div class="card-header bg-light small text-muted">@_items.Count result(s)</div>
        <div class="card-body p-0">
            @if (_items.Count == 0)
            {
                <div class="text-center py-4 text-muted">No addresses found for the given search criteria.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ZIP</th>
                                <th>City</th>
                                <th>Canton</th>
                                <th>Municipality</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _items)
                            {
                                <tr>
                                    <td><code>@a.ZipCode</code></td>
                                    <td>@a.City</td>
                                    <td>@a.Canton</td>
                                    <td class="text-muted">@(a.Municipality ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<SwissAddressResponse>? _items;
    private bool _searching;
    private string _filterZip = string.Empty, _filterCity = string.Empty, _filterCanton = string.Empty;

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_filterZip) && string.IsNullOrWhiteSpace(_filterCity) && string.IsNullOrWhiteSpace(_filterCanton))
            return;
        _searching = true;
        try
        {
            if (!string.IsNullOrWhiteSpace(_filterZip))
                _items = await Service.SearchByZipCodeAsync(_filterZip);
            else if (!string.IsNullOrWhiteSpace(_filterCanton))
                _items = await Service.SearchByCantonAsync(_filterCanton);
            else
            {
                var result = await Service.GetPagedAsync(1, 50);
                _items = result.Items
                    .Where(a => string.IsNullOrWhiteSpace(_filterCity) || a.City.Contains(_filterCity, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }
        }
        finally { _searching = false; }
    }

    private void Reset()
    {
        _filterZip = _filterCity = _filterCanton = string.Empty;
        _items = null;
    }
}
