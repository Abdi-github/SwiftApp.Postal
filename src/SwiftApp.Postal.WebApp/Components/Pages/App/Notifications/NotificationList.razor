@page "/app/notifications"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "ADMIN")]
@inject SwiftApp.Postal.Modules.Notification.Application.Services.NotificationService Service
@using SwiftApp.Postal.Modules.Notification.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Notification Log — Swiss Postal</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-bell me-2" style="color:#1a237e"></i>Notification Log</h2>
    <div class="d-flex gap-2">
        <a href="/app/notifications/templates" class="btn btn-outline-primary">
            <i class="bi bi-file-earmark-code me-1"></i> Templates
        </a>
        <a href="/app/notifications/send-inapp" class="btn btn-outline-success">
            <i class="bi bi-megaphone me-1"></i> Send In-App
        </a>
        <a href="/app/notifications/send" class="btn btn-primary">
            <i class="bi bi-envelope-plus me-1"></i> Send Email
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="text-center py-5 text-muted"><i class="bi bi-bell-slash fs-1 d-block mb-2"></i>No notification records found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Subject</th>
                            <th>Recipient</th>
                            <th>Type</th>
                            <th>Event</th>
                            <th>Status</th>
                            <th>Sent</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var n in _items)
                        {
                            <tr>
                                <td>@(n.Subject ?? "—")</td>
                                <td class="text-muted small">@(n.RecipientEmail ?? "—")</td>
                                <td><span class="badge bg-info-subtle text-info-emphasis">@n.Type</span></td>
                                <td><span class="text-muted small">@(n.EventType ?? "—")</span></td>
                                <td><StatusBadge Status="@n.Status" /></td>
                                <td class="text-muted small">@n.CreatedAt.LocalDateTime.ToString("dd.MM.yy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3">
                <Pagination CurrentPage="_page" TotalPages="_totalPages" TotalItems="_totalItems" OnPageChange="ChangePage" />
            </div>
        }
    </div>
</div>

@code {
    private List<NotificationLogResponse> _items = [];
    private int _page = 1, _totalPages, _totalItems;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await Service.GetLogsPagedAsync(_page, 20);
            _items = result.Items.ToList();
            _totalPages = result.TotalPages;
            _totalItems = (int)result.TotalItems;
        }
        finally { _loading = false; }
    }

    private async Task ChangePage(int page) { _page = page; await LoadAsync(); }
}
