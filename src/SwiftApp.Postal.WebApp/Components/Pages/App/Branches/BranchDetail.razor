@page "/app/branches/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "ManagerOrAdmin")]
@inject SwiftApp.Postal.Modules.Branch.Application.Services.BranchService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Branch.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Branch Detail — Swiss Postal</PageTitle>

@if (_branch is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="bi bi-building me-2" style="color:#1a237e"></i>@_branch.Name</h2>
        <div class="d-flex gap-2">
            <a href="/app/branches/@_branch.Id/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <a href="/app/branches" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-semibold">Branch Information</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Code</dt>
                        <dd class="col-sm-8"><code>@_branch.BranchCode</code></dd>
                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8"><span class="badge bg-info-subtle text-info-emphasis">@_branch.Type</span></dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8"><StatusBadge Status="@_branch.Status" /></dd>
                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(_branch.Description ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-semibold">Location</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">@_branch.Street</dd>
                        <dt class="col-sm-4">ZIP / City</dt>
                        <dd class="col-sm-8">@_branch.ZipCode @_branch.City</dd>
                        <dt class="col-sm-4">Canton</dt>
                        <dd class="col-sm-8">@(_branch.Canton ?? "—")</dd>
                        <dt class="col-sm-4">Phone</dt>
                        <dd class="col-sm-8">@(_branch.Phone ?? "—")</dd>
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(_branch.Email ?? "—")</dd>
                        @if (_branch.Latitude.HasValue)
                        {
                            <dt class="col-sm-4">Coordinates</dt>
                            <dd class="col-sm-8 text-muted small">@_branch.Latitude.Value.ToString("F4"), @_branch.Longitude!.Value.ToString("F4")</dd>
                        }
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private BranchResponse? _branch;

    protected override async Task OnInitializedAsync()
    {
        try { _branch = await Service.GetByIdAsync(Id, "de-CH"); }
        catch { Nav.NavigateTo("/app/branches"); }
    }
}
