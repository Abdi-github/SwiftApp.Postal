@page "/app/employees/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "ManagerOrAdmin")]
@inject SwiftApp.Postal.Modules.Auth.Application.Services.EmployeeService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Auth.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Employee Detail — Swiss Postal</PageTitle>

@if (_emp is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="bi bi-person me-2" style="color:#1a237e"></i>@_emp.FirstName @_emp.LastName</h2>
        <div class="d-flex gap-2">
            <a href="/app/employees/@_emp.Id/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <a href="/app/employees" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-semibold">Personal Information</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Employee #</dt>
                        <dd class="col-sm-8"><code>@_emp.EmployeeNumber</code></dd>
                        <dt class="col-sm-4">Full Name</dt>
                        <dd class="col-sm-8">@_emp.FirstName @_emp.LastName</dd>
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@_emp.Email</dd>
                        <dt class="col-sm-4">Phone</dt>
                        <dd class="col-sm-8">@(_emp.Phone ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light fw-semibold">Employment Details</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Role</dt>
                        <dd class="col-sm-8"><span class="badge bg-primary-subtle text-primary-emphasis">@_emp.Role</span></dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8"><StatusBadge Status="@_emp.Status" /></dd>
                        <dt class="col-sm-4">Hire Date</dt>
                        <dd class="col-sm-8">@_emp.HireDate.ToString("dd.MM.yyyy")</dd>
                        <dt class="col-sm-4">Locale</dt>
                        <dd class="col-sm-8">@_emp.PreferredLocale</dd>
                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8 text-muted small">@_emp.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private EmployeeResponse? _emp;

    protected override async Task OnInitializedAsync()
    {
        try { _emp = await Service.GetByIdAsync(Id); }
        catch { Nav.NavigateTo("/app/employees"); }
    }
}
