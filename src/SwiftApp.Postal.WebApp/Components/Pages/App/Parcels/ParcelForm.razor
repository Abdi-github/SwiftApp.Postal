@page "/app/parcels/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject SwiftApp.Postal.Modules.Parcel.Application.Services.ParcelService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Parcel.Application.DTOs

<PageTitle>Send Parcel — Swiss Postal</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-box-seam me-2" style="color:#1a237e"></i>Send Parcel</h2>
    <a href="/app/parcels" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-circle me-1"></i>@_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="row g-4">
            <!-- Service Type & Dimensions -->
            <div class="col-12">
                <h5 class="fw-semibold text-primary mb-3"><i class="bi bi-box me-2"></i>Parcel Details</h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Service Type <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_type">
                            <option value="">-- Select --</option>
                            <option value="Standard">Standard</option>
                            <option value="Priority">Priority</option>
                            <option value="Express">Express</option>
                            <option value="Registered">Registered</option>
                            <option value="Insured">Insured</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Weight (kg)</label>
                        <input type="number" step="0.001" min="0" class="form-control" @bind="_weightKg" placeholder="1.500" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Length (cm)</label>
                        <input type="number" step="0.1" min="0" class="form-control" @bind="_lengthCm" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Width (cm)</label>
                        <input type="number" step="0.1" min="0" class="form-control" @bind="_widthCm" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Height (cm)</label>
                        <input type="number" step="0.1" min="0" class="form-control" @bind="_heightCm" />
                    </div>
                </div>
            </div>

            <!-- Sender -->
            <div class="col-md-6">
                <h5 class="fw-semibold text-primary mb-3"><i class="bi bi-person-up me-2"></i>Sender</h5>
                <div class="row g-2">
                    <div class="col-12">
                        <input class="form-control" @bind="_senderName" placeholder="Full name *" />
                    </div>
                    <div class="col-12">
                        <input class="form-control" @bind="_senderStreet" placeholder="Street *" />
                    </div>
                    <div class="col-4">
                        <input class="form-control" @bind="_senderZip" placeholder="ZIP *" />
                    </div>
                    <div class="col-8">
                        <input class="form-control" @bind="_senderCity" placeholder="City *" />
                    </div>
                    <div class="col-12">
                        <input class="form-control" @bind="_senderPhone" placeholder="Phone" />
                    </div>
                </div>
            </div>

            <!-- Recipient -->
            <div class="col-md-6">
                <h5 class="fw-semibold text-primary mb-3"><i class="bi bi-person-down me-2"></i>Recipient</h5>
                <div class="row g-2">
                    <div class="col-12">
                        <input class="form-control" @bind="_recipientName" placeholder="Full name *" />
                    </div>
                    <div class="col-12">
                        <input class="form-control" @bind="_recipientStreet" placeholder="Street *" />
                    </div>
                    <div class="col-4">
                        <input class="form-control" @bind="_recipientZip" placeholder="ZIP *" />
                    </div>
                    <div class="col-8">
                        <input class="form-control" @bind="_recipientCity" placeholder="City *" />
                    </div>
                    <div class="col-12">
                        <input class="form-control" @bind="_recipientPhone" placeholder="Phone" />
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-send me-1"></i> Send Parcel
            </button>
            <a href="/app/parcels" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </div>
</div>

@code {
    private bool _saving;
    private string? _errorMessage;
    private string _type = string.Empty;
    private decimal? _weightKg, _lengthCm, _widthCm, _heightCm;
    private string _senderName = string.Empty, _senderStreet = string.Empty, _senderZip = string.Empty, _senderCity = string.Empty;
    private string? _senderPhone;
    private string _recipientName = string.Empty, _recipientStreet = string.Empty, _recipientZip = string.Empty, _recipientCity = string.Empty;
    private string? _recipientPhone;

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_type) || string.IsNullOrWhiteSpace(_senderName) ||
            string.IsNullOrWhiteSpace(_senderZip) || string.IsNullOrWhiteSpace(_senderCity) ||
            string.IsNullOrWhiteSpace(_recipientName) || string.IsNullOrWhiteSpace(_recipientZip) || string.IsNullOrWhiteSpace(_recipientCity))
        {
            _errorMessage = "Please fill in all required fields.";
            return;
        }
        _saving = true;
        try
        {
            var req = new ParcelRequest(_type, _weightKg, _lengthCm, _widthCm, _heightCm,
                null, null, _senderName, _senderStreet, _senderZip, _senderCity, _senderPhone,
                _recipientName, _recipientStreet, _recipientZip, _recipientCity, _recipientPhone);
            var result = await Service.CreateAsync(req);
            Nav.NavigateTo($"/app/parcels/{result.Id}");
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }
}
