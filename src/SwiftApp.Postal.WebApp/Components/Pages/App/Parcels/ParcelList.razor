@page "/app/parcels"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject SwiftApp.Postal.Modules.Parcel.Application.Services.ParcelService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Parcel.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Parcels — Swiss Postal</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-box-seam me-2" style="color:#1a237e"></i>Parcels</h2>
    <a href="/app/parcels/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Send Parcel
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="text-center py-5 text-muted"><i class="bi bi-box-seam fs-1 d-block mb-2"></i>No parcels found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tracking #</th>
                            <th>Type</th>
                            <th>Sender</th>
                            <th>Recipient</th>
                            <th>Status</th>
                            <th class="text-end">Price (CHF)</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _items)
                        {
                            <tr>
                                <td><code class="small">@p.TrackingNumber</code></td>
                                <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@p.Type</span></td>
                                <td class="small">@p.SenderName<br /><span class="text-muted">@p.SenderZipCode @p.SenderCity</span></td>
                                <td class="small">@p.RecipientName<br /><span class="text-muted">@p.RecipientZipCode @p.RecipientCity</span></td>
                                <td><StatusBadge Status="@p.Status" /></td>
                                <td class="text-end fw-semibold">@p.Price.ToString("N2")</td>
                                <td class="text-muted small">@p.CreatedAt.LocalDateTime.ToString("dd.MM.yy")</td>
                                <td class="text-end">
                                    <a href="/app/parcels/@p.Id" class="btn btn-sm btn-outline-secondary me-1">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/app/tracking/@p.TrackingNumber" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-geo-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3">
                <Pagination CurrentPage="_page" TotalPages="_totalPages" TotalItems="_totalItems" OnPageChange="ChangePage" />
            </div>
        }
    </div>
</div>

@code {
    private List<ParcelResponse> _items = [];
    private int _page = 1, _totalPages, _totalItems;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await Service.GetPagedAsync(_page, 20);
            _items = result.Items.ToList();
            _totalPages = result.TotalPages;
            _totalItems = (int)result.TotalItems;
        }
        finally { _loading = false; }
    }

    private async Task ChangePage(int page) { _page = page; await LoadAsync(); }
}
