@page "/app/customers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "ManagerOrAdmin")]
@inject SwiftApp.Postal.Modules.Auth.Application.Services.CustomerService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Auth.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Customers — Swiss Postal</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-person-badge me-2" style="color:#1a237e"></i>Customers</h2>
    <a href="/app/customers/new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Customer
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="text-center py-5 text-muted"><i class="bi bi-person-badge fs-1 d-block mb-2"></i>No customers found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Customer #</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th>Registered</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _items)
                        {
                            <tr>
                                <td><code class="small">@c.CustomerNumber</code></td>
                                <td>@c.FirstName @c.LastName</td>
                                <td class="text-muted small">@c.Email</td>
                                <td class="text-muted small">@(c.Phone ?? "—")</td>
                                <td><StatusBadge Status="@c.Status" /></td>
                                <td class="text-muted small">@c.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy")</td>
                                <td class="text-end">
                                    <a href="/app/customers/@c.Id" class="btn btn-sm btn-outline-secondary me-1">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/app/customers/@c.Id/edit" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-3">
                <Pagination CurrentPage="_page" TotalPages="_totalPages" TotalItems="_totalItems" OnPageChange="ChangePage" />
            </div>
        }
    </div>
</div>

@code {
    private List<CustomerResponse> _items = [];
    private int _page = 1, _totalPages, _totalItems;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await Service.GetPagedAsync(_page, 20);
            _items = result.Items.ToList();
            _totalPages = result.TotalPages;
            _totalItems = (int)result.TotalItems;
        }
        finally { _loading = false; }
    }

    private async Task ChangePage(int page) { _page = page; await LoadAsync(); }
}
