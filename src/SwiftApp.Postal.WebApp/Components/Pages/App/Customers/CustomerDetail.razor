@page "/app/customers/{Id:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "ManagerOrAdmin")]
@inject SwiftApp.Postal.Modules.Auth.Application.Services.CustomerService Service
@inject NavigationManager Nav
@using SwiftApp.Postal.Modules.Auth.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Customer Detail — Swiss Postal</PageTitle>

@if (_cust is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="bi bi-person me-2" style="color:#1a237e"></i>@_cust.FirstName @_cust.LastName</h2>
        <div class="d-flex gap-2">
            <a href="/app/customers/@_cust.Id/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <a href="/app/customers" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-light fw-semibold">Customer Information</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Customer #</dt>
                <dd class="col-sm-9"><code>@_cust.CustomerNumber</code></dd>
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">@_cust.FirstName @_cust.LastName</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@_cust.Email</dd>
                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@(_cust.Phone ?? "—")</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9"><StatusBadge Status="@_cust.Status" /></dd>
                <dt class="col-sm-3">Locale</dt>
                <dd class="col-sm-9">@_cust.PreferredLocale</dd>
                <dt class="col-sm-3">Registered</dt>
                <dd class="col-sm-9 text-muted small">@_cust.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private CustomerResponse? _cust;

    protected override async Task OnInitializedAsync()
    {
        try { _cust = await Service.GetByIdAsync(Id); }
        catch { Nav.NavigateTo("/app/customers"); }
    }
}
