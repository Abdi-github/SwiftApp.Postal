@page "/error"

<PageTitle>Error — Swiss Postal</PageTitle>

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4" style="font-size: 5rem; color: #dc3545;">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h2 class="fw-bold text-danger">Something went wrong</h2>
        <p class="text-muted mb-4">An unexpected error occurred. Please try again or contact support.</p>
        <a href="/app" class="btn btn-primary">
            <i class="bi bi-house me-1"></i> Back to Dashboard
        </a>
    </div>
</div>
