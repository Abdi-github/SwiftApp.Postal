@page "/tracking/{TrackingNumber?}"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject SwiftApp.Postal.Modules.Tracking.Application.Services.TrackingService Service
@using SwiftApp.Postal.Modules.Tracking.Application.DTOs
@using SwiftApp.Postal.WebApp.Components.Shared

<PageTitle>Track Your Parcel — Swiss Postal</PageTitle>

<div class="container py-5" style="max-width:700px">
    <div class="text-center mb-5">
        <i class="bi bi-geo-alt-fill display-4" style="color:#1a237e"></i>
        <h1 class="h3 fw-bold mt-3" style="color:#1a237e">Track Your Parcel</h1>
        <p class="text-muted">Enter your tracking number to see the current status and delivery history</p>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-body p-4">
            <div class="input-group input-group-lg">
                <input class="form-control font-monospace" @bind="_query" @bind:event="oninput" placeholder="CHE..." maxlength="20"
                       @onkeydown="OnKeyDown" />
                <button class="btn btn-primary px-4" @onclick="SearchAsync" disabled="@_searching">
                    @if (_searching) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    <i class="bi bi-search me-1"></i> Track
                </button>
            </div>
        </div>
    </div>

    @if (_notFound)
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-question-circle fs-4 d-block mb-2"></i>
            <strong>No parcel found</strong><br />
            <span class="small">No parcel found for tracking number <code>@_query</code>. Please double-check and try again.</span>
        </div>
    }
    else if (_timeline is not null)
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white fw-semibold py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-seam me-2"></i><code class="text-white">@_timeline.TrackingNumber</code></span>
                    <StatusBadge Status="@_timeline.CurrentStatus" />
                </div>
            </div>
            <div class="card-body p-0">
                @if (_timeline.Events.Count == 0)
                {
                    <p class="text-muted text-center py-4 mb-0">No tracking events available yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0 px-4 pt-4">
                        @foreach (var ev in _timeline.Events.OrderByDescending(e => e.EventTimestamp))
                        {
                            bool isFirst = ev == _timeline.Events.OrderByDescending(e => e.EventTimestamp).First();
                            <li class="d-flex mb-4">
                                <div class="me-3 mt-1">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                                         style="width:32px;height:32px;background:@(isFirst ? "#1a237e" : "#e9ecef")">
                                        <i class="bi bi-circle-fill text-@(isFirst ? "white" : "muted")" style="font-size:0.5rem"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 pb-3 border-bottom">
                                    <div class="fw-semibold">@ev.EventType</div>
                                    @if (ev.DescriptionKey is not null)
                                    {
                                        <div class="text-muted small">@ev.DescriptionKey</div>
                                    }
                                    <div class="d-flex gap-3 mt-1">
                                        @if (ev.Location is not null)
                                        {
                                            <span class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@ev.Location</span>
                                        }
                                        <span class="text-muted small"><i class="bi bi-clock me-1"></i>@ev.EventTimestamp.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? TrackingNumber { get; set; }
    private string _query = string.Empty;
    private bool _searching, _notFound;
    private TrackingTimelineResponse? _timeline;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(TrackingNumber))
        {
            _query = TrackingNumber;
            await SearchAsync();
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;
        _searching = true; _notFound = false; _timeline = null;
        try
        {
            _timeline = await Service.GetTimelineAsync(_query.Trim().ToUpper());
            if (_timeline is null) _notFound = true;
        }
        catch { _notFound = true; }
        finally { _searching = false; }
    }
}
